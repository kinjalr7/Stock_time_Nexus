# ── Stock Time Nexus – Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# The backend auto-loads .env on startup (requires python-dotenv).

# ── Phase 3: AI Chatbot ────────────────────────────────────────────────────────
# Choose ONE of the providers below and fill in the matching values.

# ════════════════════════════════════════════════════════════════════════════════
# OPTION A — HuggingFace Inference API (FREE tier available!)
#   1. Sign up at https://huggingface.co
#   2. Go to Settings → Access Tokens → New token (read scope is enough)
#   3. Paste the token below
# ════════════════════════════════════════════════════════════════════════════════
OPENAI_API_KEY=hhf_flGnVTEWKwSLteBBTHBQAJTASEmZtCDYBE
OPENAI_BASE_URL=https://api-inference.huggingface.co/v1

# Recommended free models (pick one, paste into CHAT_MODEL):
#   mistralai/Mistral-7B-Instruct-v0.3      ← great all-round (recommended)
#   HuggingFaceH4/zephyr-7b-beta            ← good for chat
#   microsoft/Phi-3-mini-4k-instruct        ← fast & lightweight
#   meta-llama/Meta-Llama-3-8B-Instruct     ← requires HF Pro or approved access
CHAT_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ════════════════════════════════════════════════════════════════════════════════
# OPTION B — OpenAI  (comment out Option A and uncomment below)
# ════════════════════════════════════════════════════════════════════════════════
# OPENAI_API_KEY=sk-YOUR_OPENAI_KEY
# OPENAI_BASE_URL=https://api.openai.com/v1
# CHAT_MODEL=gpt-4o-mini

# ════════════════════════════════════════════════════════════════════════════════
# OPTION C — Groq  (OpenAI-compatible, very fast, generous free tier)
#   Get key at: https://console.groq.com
# ════════════════════════════════════════════════════════════════════════════════
# OPENAI_API_KEY=gsk_YOUR_GROQ_KEY
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# CHAT_MODEL=llama3-8b-8192

# ── Phase 1: Persistence ───────────────────────────────────────────────────────
# Path to the SQLite database file (default: stock_nexus.db in project root)
DB_PATH=stock_nexus.db

# ── Phase 4: Production ────────────────────────────────────────────────────────
# Secret key for JWT tokens (change this to a long random string in production!)
SECRET_KEY=changeme-use-a-long-random-string-in-production

# Backend server settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
